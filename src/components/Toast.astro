---
---
<div
  id="toast-container"
  class="fixed bottom-5 right-5 z-50 flex flex-col gap-2 pointer-events-none"
></div>

<template id="toast-template">
  <div class="toast-item flex items-center p-4 mb-2 w-full max-w-xs text-slate-500 bg-white rounded-xl shadow-xl dark:text-slate-400 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 pointer-events-auto transform translate-y-4 opacity-0 transition-all duration-300" role="alert">
    <div class="inline-flex flex-shrink-0 justify-center items-center w-8 h-8 rounded-lg toast-icon-container">
      <!-- Dynamic Icon SVG will go here -->
    </div>
    <div class="ml-3 text-sm font-medium text-slate-800 dark:text-slate-200 toast-message"></div>
    <button type="button" class="ml-auto -mx-1.5 -my-1.5 bg-white text-slate-400 hover:text-slate-900 rounded-lg focus:ring-2 focus:ring-slate-300 p-1.5 hover:bg-slate-100 inline-flex h-8 w-8 dark:text-slate-500 dark:hover:text-white dark:bg-slate-800 dark:hover:bg-slate-700 toast-close-btn cursor-pointer" aria-label="Close">
      <span class="sr-only">Cerrar</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</template>

<script is:inline>
  // Expose showToast globally
  window.showToast = (message, type = 'success') => {
    const container = document.getElementById('toast-container');
    const template = document.getElementById('toast-template');
    if (!container || !template) return;

    // Clone template content
    const clone = template.content.cloneNode(true);
    const toastItem = clone.querySelector('.toast-item');
    const iconContainer = clone.querySelector('.toast-icon-container');
    const messageContainer = clone.querySelector('.toast-message');
    const closeBtn = clone.querySelector('.toast-close-btn');

    if (!toastItem || !iconContainer || !messageContainer || !closeBtn) return;

    messageContainer.textContent = message;

    // Type styles and SVGs
    if (type === 'success') {
      iconContainer.classList.add('bg-emerald-100', 'text-emerald-600', 'dark:bg-emerald-950/50', 'dark:text-emerald-400');
      iconContainer.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>`;
    } else if (type === 'error') {
      iconContainer.classList.add('bg-rose-100', 'text-rose-600', 'dark:bg-rose-950/50', 'dark:text-rose-400');
      iconContainer.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>`;
    } else if (type === 'info') {
      iconContainer.classList.add('bg-sky-100', 'text-sky-600', 'dark:bg-sky-950/50', 'dark:text-sky-400');
      iconContainer.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
    } else if (type === 'warning') {
      iconContainer.classList.add('bg-amber-100', 'text-amber-600', 'dark:bg-amber-950/50', 'dark:text-amber-400');
      iconContainer.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>`;
    }

    // Append to container
    container.appendChild(toastItem);

    // Trigger entrance animation
    setTimeout(() => {
      toastItem.classList.remove('translate-y-4', 'opacity-0');
      toastItem.classList.add('translate-y-0', 'opacity-100');
    }, 10);

    // Dismiss function
    const dismiss = () => {
      toastItem.classList.remove('translate-y-0', 'opacity-100');
      toastItem.classList.add('translate-y-4', 'opacity-0');
      setTimeout(() => {
        toastItem.remove();
      }, 300);
    };

    closeBtn.addEventListener('click', dismiss);

    // Auto-dismiss after 4 seconds
    setTimeout(dismiss, 4000);
  };
</script>
